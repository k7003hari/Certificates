	private String getBranchCode(Long agreementId) {
		Log.debug(this.getClass(),"CR11507:: inside getBranchCode" );
		DBean db = null;
		PreparedStatement pstmt = null;
		ResultSet rs = null;
		
		String branchCode=null;
		try {

			db = new DBean(false);
			db.connect();
			Connection con = db.getConnection();

			String sql3 = "select BRANCH_CODE from generalsystem.v_ptm_branch where party_id in (select PARTY_ID from generalsystem.t_agt_agreement where agreement_id=?)";

			Log.debug(this.getClass(), "CR11507:: inside getBranchCode:Select SQL::::::::" + sql3);

			pstmt = con.prepareStatement(sql3);
			 pstmt.setLong(1, agreementId);
			rs = pstmt.executeQuery();

			while (null != rs && rs.next()) {
				branchCode=rs.getString("BRANCH_CODE");
			}
			System.out.println("branch code::::" + branchCode);

		} catch (Exception e) {
			Log.debug(this.getClass(), "CR11507:: inside getBranchCode:" + e);
		} finally {
			DBean.closeAll(rs, pstmt, db);
		}

		return branchCode;
	}

